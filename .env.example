# ============================================
# GridGuard — Environment Variables
# ============================================
# Copy this to .env.local for local development.

# --- Supabase Configuration ---
# Get these from your Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI & Translation ---
# Get an OpenRouter key at https://openrouter.ai
OPENROUTER_API_KEY=your-openrouter-key
# (Optional) If using Google Gemini directly
GEMINI_API_KEY=your-gemini-key

# --- Authentication & Sessions ---
# Generate a secure 32+ character random string
JWT_SECRET=your-random-jwt-secret

# --- Email / Resend ---
# Get a key at https://resend.com
RESEND_API_KEY=your-resend-key

# --- Cron Job Security ---
# Set this to a random string and configure in Vercel dashboard
CRON_SECRET=your-cron-secret

# --- Other Configuration ---
# (Optional) For local dev with MailHog
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@gridguard.app
