# ============================================
# GridGuard — Environment Variables
# ============================================
# Copy this to .env.local for local development.

# --- Gemini API (for Amharic → English translation) ---
# Get a free key at: https://ai.google.dev
GEMINI_API_KEY=your-gemini-key-here

# --- Email / SMTP ---
# For local dev with MailHog: host=localhost, port=1025
# For production: use your SMTP provider (SendGrid, Resend, etc.)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@gridguard.et

# --- Authentication ---
# Generate a secure random string for JWT signing
JWT_SECRET=change-me-to-a-secure-random-string

# --- Cron Job Security ---
# Set this to a random string and configure in Vercel dashboard
CRON_SECRET=

# --- Database (optional, for future Vercel Postgres integration) ---
# POSTGRES_URL=
